<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Config Sanitizer"
    Manufacturer="Andrevillien"
    Version="$(var.ProductVersion)"
    UpgradeCode="2C357B6D-A786-4425-B869-5E65450F6536"
    Scope="perMachine"
    Language="1033">

    <MediaTemplate EmbedCab="yes" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Config Sanitizer is already installed." />

    <Icon Id="AppIcon.ico" SourceFile="$(sys.SOURCEFILEDIR)..\assets\config-sanitizer.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Config Sanitizer">
        <Component Id="MainExecutableComponent" Guid="*">
          <File Id="MainExecutable" Source="$(var.ExecutablePath)" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppProgramMenuDir" Name="Config Sanitizer">
        <Component Id="StartMenuShortcutComponent" Guid="*">
          <Shortcut
            Id="StartMenuShortcut"
            Name="Config Sanitizer"
            Description="Launch Config Sanitizer"
            Target="[INSTALLFOLDER]ConfigSanitizer.exe"
            WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="RemoveAppProgramMenuDir" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\Andrevillien\ConfigSanitizer" Name="installed" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Config Sanitizer" Level="1">
      <ComponentRef Id="MainExecutableComponent" />
      <ComponentRef Id="StartMenuShortcutComponent" />
    </Feature>

    <UIRef Id="WixUI_Minimal" />
  </Package>
</Wix>
